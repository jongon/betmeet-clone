# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL="postgresql://username:password@postgres:5432/nextjs"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Application
NEXT_PUBLIC_SITE_URL="http://app:3000"

SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# API-Football provider (optional — only needed for /admin sync)
API_FOOTBALL_KEY="your-api-key"

WORLD_CUP_KICKOFF="2026-06-11T18:00:00Z"
NODE_ENV="development"

# Email transaccional (Unit 9 / FR-EMAIL-01)
# El emisor es Supabase Auth con Resend como Custom SMTP. La app NO envía correos
# directamente, así que no hay var de runtime nueva: los enlaces siguen usando
# NEXT_PUBLIC_SITE_URL. El SMTP de Resend se configura en Supabase
# (Auth > SMTP Settings, o [auth.email.smtp] en supabase/config.toml).
# Las siguientes solo se consumen desde config.toml si activas ese bloque:
#   RESEND_SMTP_PASSWORD="re_xxxxxxxx"          # API key de Resend (host smtp.resend.com)
#   EMAIL_FROM="no-reply@tu-dominio.com"        # dev: usa el sandbox resend.dev; prod: dominio verificado (DKIM/SPF/DMARC)

# Web Push (Unit 10)
# Generate once per environment with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"

VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"
