# PostgreSQL runtime connection string.
# Use the transaction pooler in hosted Supabase/production.
DATABASE_URL="postgresql://username:password@postgres:5432/nextjs"

# PostgreSQL direct connection string.
# Used by Prisma CLI commands: migrate, introspect, Studio, generate datasource checks.
DIRECT_URL="postgresql://username:password@postgres:5432/nextjs"

# Conexiones que cada instancia serverless mantiene abiertas contra el pooler.
# Opcional; default 5 (src/lib/prisma.ts). Con Vercel Fluid Compute una instancia
# atiende varias requests concurrentes, así que un límite muy bajo encola queries.
# No debe superar el Pool Size del transaction pooler de Supabase.
DB_CONNECTION_LIMIT="5"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Application
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# football-data.org provider (Unit 25) — free tier: 10 req/min, World Cup coverage
# Get a key at https://www.football-data.org/client/register
FOOTBALL_DATA_KEY="your-football-data-api-key"

WORLD_CUP_KICKOFF="2026-06-11T18:00:00Z"
NODE_ENV="development"

# Sync trigger guard (Unit 50) — secret required by the automated cron/dispatch
# routes (/api/cron/sync, /api/notifications/dispatch). The route validates the
# `x-sync-secret` header against this value. The Supabase pg_cron jobs read it
# (and the app base URL) from Supabase Vault as `sync_trigger_secret` and
# `app_base_url` — never hardcoded in SQL. Leave empty to disable the guard (dev only).
SYNC_TRIGGER_SECRET="your-long-random-secret"

# Email transaccional (Unit 72 — migración a Resend / antes Unit 9)
# La APP envía los correos de auth directamente con Resend vía el Send Email Hook
# de Supabase (POST /api/auth/email-hook). El SMTP de Supabase queda DESACTIVADO.
RESEND_API_KEY="re_xxxxxxxx"                   # API key de Resend (SDK)
EMAIL_FROM="Quiniela Mundial 2026 <no-reply@tu-dominio.com>"  # dev: sandbox resend.dev; prod: dominio verificado (DKIM/SPF/DMARC)
# Secreto compartido del Send Email Hook (Auth > Hooks en Supabase). Formato
# `v1,whsec_<base64>`. El endpoint verifica la firma (Standard Webhooks) y
# rechaza con 401 si no coincide.
SEND_EMAIL_HOOK_SECRET="v1,whsec_your-base64-secret"

# Web Push (Unit 10)
# Generate once per environment with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"

VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"
