# PostgreSQL connection string (matches docker-compose defaults)
DATABASE_URL="postgresql://username:password@postgres:5432/nextjs"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Application
NEXT_PUBLIC_SITE_URL="http://app:3000"

SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# API-Football provider (optional — only needed for /admin sync)
API_FOOTBALL_KEY="your-api-key"

WORLD_CUP_KICKOFF="2026-06-11T18:00:00Z"
NODE_ENV="development"

# Web Push (Unit 10)
# Generate once per environment with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@example.com"
