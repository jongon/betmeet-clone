generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Verification tiers for platform access control
enum VerificationStatus {
  UNVERIFIED
  VERIFIED
  ADMIN
}

// Source of the currently active avatar image
enum AvatarSource {
  GOOGLE_PHOTO
  DEFAULT_SET
  CUSTOM_UPLOAD
}

// User public identity — extends Supabase auth.users (shared UUID primary key)
model Profile {
  id                    String             @id @db.Uuid
  nicknameBase          String?            @map("nickname_base") @db.VarChar(20)
  nicknameDiscriminator String?            @map("nickname_discriminator") @db.Char(4)
  avatarUrl             String             @map("avatar_url")
  avatarSource          AvatarSource       @default(DEFAULT_SET) @map("avatar_source")
  verificationStatus    VerificationStatus @default(UNVERIFIED) @map("verification_status")
  mfaEnabled            Boolean            @default(false) @map("mfa_enabled")
  nicknameUpdatedAt     DateTime?          @map("nickname_updated_at")
  nicknameChangeCount   Int                @default(0) @map("nickname_change_count")
  onboardingCompleted   Boolean            @default(false) @map("onboarding_completed")
  locale                String             @default("es") @db.VarChar(2)
  deletedAt             DateTime?          @map("deleted_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  ownedPools       Pool[]            @relation("PoolOwner")
  poolMemberships  PoolMembership[]
  predictions      Prediction[]
  predictionScores PredictionScore[]
  notificationPreference NotificationPreference?
  pushSubscriptions      PushSubscription[]
  notificationEvents     NotificationEvent[]
  poolDirectedInvites    PoolDirectedInvite[] @relation("PoolDirectedInviteRecipient")
  createdPoolInvites     PoolDirectedInvite[] @relation("PoolDirectedInviteCreator")

  @@unique([nicknameBase, nicknameDiscriminator])
  @@index([deletedAt])
  @@map("profiles")
}

// Server-side cooldown for email-bound actions (resend confirmation, change
// unconfirmed email). Keyed by email because unconfirmed accounts may not have a
// profile yet. Written/read only by server actions (Prisma privileged role); RLS
// denies direct authenticated/anon access. See FR-REFINE-12.2 (Unit 12).
model EmailActionThrottle {
  id         String   @id @default(uuid()) @db.Uuid
  email      String   @db.VarChar(255)
  action     String   @db.VarChar(40)
  lastSentAt DateTime @default(now()) @map("last_sent_at")

  @@unique([email, action])
  @@map("email_action_throttle")
}

// Default avatar set — seeded via scripts/seed-avatars.ts
model AvatarAsset {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(80)
  storagePath  String   @map("storage_path")
  storageUrl   String   @map("storage_url")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("avatar_assets")
}

// Pool visibility (Unit 3)
enum PoolType {
  PUBLIC
  PRIVATE
}

enum CompetitionPhaseType {
  GROUP
  KNOCKOUT
  LEAGUE
}

enum MatchStatus {
  SCHEDULED
  LOCKED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum ProviderSyncStatus {
  STARTED
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
  RATE_LIMITED
  SKIPPED_LOCKED
}

enum ProviderSyncScope {
  TEAMS
  FIXTURES
  LIVE_STATUS
  RESULTS
  FULL
  CLEANUP
}

// A competition group where users compete (US-4.1)
model Pool {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(60)
  type        PoolType
  capacity    Int
  inviteToken String   @unique @map("invite_token") @db.VarChar(12)
  ownerId     String   @map("owner_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  owner       Profile          @relation("PoolOwner", fields: [ownerId], references: [id])
  memberships PoolMembership[]
  directedInvites PoolDirectedInvite[]

  @@index([ownerId])
  @@index([type])
  @@map("pools")
}

enum PoolDirectedInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED

  @@map("pool_directed_invite_status")
}

model PoolDirectedInvite {
  id               String                   @id @default(uuid()) @db.Uuid
  poolId           String                   @map("pool_id") @db.Uuid
  invitedUserId    String?                  @map("invited_user_id") @db.Uuid
  invitedEmailHash String?                  @map("invited_email_hash") @db.VarChar(128)
  invitedNickname  String?                  @map("invited_nickname") @db.VarChar(32)
  inviteToken      String                   @map("invite_token") @db.VarChar(12)
  createdByUserId  String                   @map("created_by_user_id") @db.Uuid
  status           PoolDirectedInviteStatus @default(PENDING)
  createdAt        DateTime                 @default(now()) @map("created_at")
  acceptedAt       DateTime?                @map("accepted_at")

  pool          Pool     @relation(fields: [poolId], references: [id], onDelete: Cascade)
  invitedUser   Profile? @relation("PoolDirectedInviteRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  createdByUser Profile  @relation("PoolDirectedInviteCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@unique([poolId, invitedUserId])
  @@index([invitedUserId])
  @@index([createdByUserId])
  @@index([invitedEmailHash])
  @@index([inviteToken])
  @@map("pool_directed_invites")
}

// Membership of a user in a pool, incl. per-member personal archive (F1)
model PoolMembership {
  id         String    @id @default(uuid()) @db.Uuid
  poolId     String    @map("pool_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  joinedAt   DateTime  @default(now()) @map("joined_at")
  archivedAt DateTime? @map("archived_at")

  pool Pool    @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([poolId, userId])
  @@index([userId])
  @@map("pool_memberships")
}

model Competition {
  id                    String   @id @default(uuid()) @db.Uuid
  slug                  String   @unique @db.VarChar(80)
  name                  String   @db.VarChar(120)
  season                String   @db.VarChar(20)
  startsAt              DateTime? @map("starts_at")
  endsAt                DateTime? @map("ends_at")
  timezone              String   @default("UTC") @db.VarChar(80)
  provider              String?  @db.VarChar(40)
  providerCompetitionId String?  @map("provider_competition_id") @db.VarChar(80)
  isActive              Boolean  @default(false) @map("is_active")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  phases CompetitionPhase[]
  matches Match[]

  @@index([isActive])
  @@map("competitions")
}

model CompetitionPhase {
  id              String               @id @default(uuid()) @db.Uuid
  competitionId   String               @map("competition_id") @db.Uuid
  name            String               @db.VarChar(120)
  type            CompetitionPhaseType
  groupCode       String?              @map("group_code") @db.VarChar(8)
  displayOrder    Int                  @map("display_order")
  startsAt        DateTime?            @map("starts_at")
  endsAt          DateTime?            @map("ends_at")
  providerPhaseId String?              @map("provider_phase_id") @db.VarChar(80)

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  matches     Match[]

  @@unique([competitionId, displayOrder])
  @@index([competitionId, type])
  @@map("competition_phases")
}

model Team {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(120)
  fifaCode       String   @unique @map("fifa_code") @db.Char(3)
  isoAlpha2      String?  @map("iso_alpha2") @db.VarChar(12)
  flagKey        String   @map("flag_key") @db.VarChar(24)
  flagPath       String   @map("flag_path") @db.VarChar(120)
  providerTeamId String?  @map("provider_team_id") @db.VarChar(80)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  homeMatches   Match[] @relation("MatchHomeTeam")
  awayMatches   Match[] @relation("MatchAwayTeam")
  winnerMatches Match[] @relation("MatchWinnerTeam")
  penaltyPredictions Prediction[] @relation("PredictionPenaltyTeam")

  @@map("teams")
}

model Match {
  id                   String      @id @default(uuid()) @db.Uuid
  competitionId        String      @map("competition_id") @db.Uuid
  phaseId              String      @map("phase_id") @db.Uuid
  providerMatchId      String?     @unique @map("provider_match_id") @db.VarChar(80)
  matchNumber          Int?        @map("match_number")
  kickoffAt            DateTime?   @map("kickoff_at")
  status               MatchStatus @default(SCHEDULED)
  rawStatus            String?     @map("raw_status") @db.VarChar(80)
  homeTeamId           String?     @map("home_team_id") @db.Uuid
  awayTeamId           String?     @map("away_team_id") @db.Uuid
  homePlaceholder      String?     @map("home_placeholder") @db.VarChar(120)
  awayPlaceholder      String?     @map("away_placeholder") @db.VarChar(120)
  homeScore            Int?        @map("home_score")
  awayScore            Int?        @map("away_score")
  homePenaltyScore     Int?        @map("home_penalty_score")
  awayPenaltyScore     Int?        @map("away_penalty_score")
  winnerTeamId         String?     @map("winner_team_id") @db.Uuid
  manualOverride       Boolean     @default(false) @map("manual_override")
  manualOverrideReason String?     @map("manual_override_reason") @db.VarChar(500)
  overriddenByUserId   String?     @map("overridden_by_user_id") @db.Uuid
  overriddenAt         DateTime?   @map("overridden_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  competition Competition      @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  phase       CompetitionPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  homeTeam    Team?            @relation("MatchHomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team?            @relation("MatchAwayTeam", fields: [awayTeamId], references: [id])
  winnerTeam  Team?            @relation("MatchWinnerTeam", fields: [winnerTeamId], references: [id])
  predictions Prediction[]
  predictionScores PredictionScore[]

  @@unique([competitionId, matchNumber])
  @@index([competitionId])
  @@index([phaseId])
  @@index([status])
  @@index([kickoffAt])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("matches")
}

model ProviderSyncRun {
  id                String             @id @default(uuid()) @db.Uuid
  provider          String             @db.VarChar(40)
  scope             ProviderSyncScope
  windowKey         String             @map("window_key") @db.VarChar(120)
  status            ProviderSyncStatus
  startedAt         DateTime           @default(now()) @map("started_at")
  finishedAt        DateTime?          @map("finished_at")
  lockExpiresAt     DateTime?          @map("lock_expires_at")
  itemsFetched      Int                @default(0) @map("items_fetched")
  itemsUpdated      Int                @default(0) @map("items_updated")
  errorMessage      String?            @map("error_message") @db.VarChar(1000)
  providerRequestId String?            @map("provider_request_id") @db.VarChar(120)
  metadata          Json?

  @@unique([provider, scope, windowKey])
  @@index([provider, scope, status])
  @@index([scope, status, finishedAt])
  @@index([startedAt])
  @@map("provider_sync_runs")
}

enum PredictionLockReason {
  KICKOFF_REACHED
  MATCH_STATUS_LOCKED
  MATCH_NOT_EDITABLE
  POSTPONED
  CANCELLED
}

model Prediction {
  id                   String                @id @default(uuid()) @db.Uuid
  userId               String                @map("user_id") @db.Uuid
  matchId              String                @map("match_id") @db.Uuid
  homeScore            Int                   @map("home_score")
  awayScore            Int                   @map("away_score")
  penaltyWinnerTeamId  String?               @map("penalty_winner_team_id") @db.Uuid
  lockedAt             DateTime?             @map("locked_at")
  lockReason           PredictionLockReason? @map("lock_reason")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  user         Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  match        Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  penaltyTeam  Team?   @relation("PredictionPenaltyTeam", fields: [penaltyWinnerTeamId], references: [id])
  score        PredictionScore?

  @@unique([userId, matchId])
  @@index([userId])
  @@index([matchId])
  @@index([lockedAt])
  @@map("predictions")
}

// Outcome of scoring one prediction against its match result (Unit 6)
enum ScoreMatchedCase {
  EXACT
  RESULT
  PARTIAL
  MISS
}

// Per-prediction computed score + breakdown (1:1 with Prediction, US-5.1)
model PredictionScore {
  id             String           @id @default(uuid()) @db.Uuid
  predictionId   String           @unique @map("prediction_id") @db.Uuid
  matchId        String           @map("match_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  matchedCase    ScoreMatchedCase @map("matched_case")
  basePoints     Int              @map("base_points")
  penaltyApplied Boolean          @default(false) @map("penalty_applied")
  penaltyPoints  Int              @default(0) @map("penalty_points")
  totalPoints    Int              @map("total_points")
  scoredAt       DateTime         @default(now()) @map("scored_at")

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  match      Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user       Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([userId])
  @@map("prediction_scores")
}

enum NotificationEventType {
  MATCH_STARTED
  MATCH_FINISHED
  POOL_INVITE
  GLOBAL_RANK_IMPROVED
  GOAL_SCORED

  @@map("notification_event_type")
}

enum NotificationEventStatus {
  PENDING
  SENT
  FAILED
  SKIPPED

  @@map("notification_event_status")
}

enum NotificationDeliveryStatus {
  SENT
  FAILED
  SKIPPED

  @@map("notification_delivery_status")
}

model NotificationPreference {
  userId             String   @id @map("user_id") @db.Uuid
  matchStarted       Boolean  @default(false) @map("match_started")
  matchFinished      Boolean  @default(false) @map("match_finished")
  poolInvite         Boolean  @default(false) @map("pool_invite")
  globalRankImproved Boolean  @default(false) @map("global_rank_improved")
  goalScored         Boolean  @default(false) @map("goal_scored")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model PushSubscription {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  endpoint      String    @unique
  p256dh        String
  auth          String
  userAgent     String?   @map("user_agent") @db.VarChar(500)
  isActive      Boolean   @default(true) @map("is_active")
  lastSuccessAt DateTime? @map("last_success_at")
  lastFailureAt DateTime? @map("last_failure_at")
  failureReason String?   @map("failure_reason") @db.VarChar(500)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user       Profile                @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, isActive])
  @@map("push_subscriptions")
}

model NotificationEvent {
  id              String                  @id @default(uuid()) @db.Uuid
  type            NotificationEventType
  dedupeKey       String                  @unique @map("dedupe_key") @db.VarChar(200)
  recipientUserId String                  @map("recipient_user_id") @db.Uuid
  payload         Json
  status          NotificationEventStatus @default(PENDING)
  createdAt       DateTime                @default(now()) @map("created_at")
  processedAt     DateTime?               @map("processed_at")

  recipient  Profile                @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([recipientUserId, status])
  @@index([status, createdAt])
  @@map("notification_events")
}

model NotificationDelivery {
  id                 String                     @id @default(uuid()) @db.Uuid
  eventId            String                     @map("event_id") @db.Uuid
  subscriptionId     String                     @map("subscription_id") @db.Uuid
  status             NotificationDeliveryStatus
  providerStatusCode Int?                       @map("provider_status_code")
  errorMessage       String?                    @map("error_message") @db.VarChar(500)
  attemptedAt        DateTime                   @default(now()) @map("attempted_at")

  event        NotificationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subscription PushSubscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([subscriptionId])
  @@map("notification_deliveries")
}
