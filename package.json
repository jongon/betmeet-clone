{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm prisma:generate",
    "dev": "next dev",
    "prebuild": "pnpm prisma:generate",
    "build": "next build",
    "start": "next start",
    "test": "DATABASE_URL=\"postgresql://username:password@postgres:5432/nextjs_test\" tsx --test --test-concurrency 1",
    "lint": "eslint",
    "format": "biome check --write",
    "check": "biome check",
    "commit": "gitmoji -c",
    "prisma:generate": "rm -rf src/generated/prisma && prisma generate",
    "prisma:studio": "prisma studio",
    "postinstall": "node scripts/generate-mcp.mjs && opencode-aidlc setup",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/types": "^12.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.108.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.78.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@content-collections/cli": "^0.1.9",
    "@content-collections/core": "^0.15.1",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/next": "^0.2.11",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/testing-library__jest-dom": "^6.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "commitlint-config-gitmoji": "^2.3.1",
    "dotenv": "^17.4.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "gitmoji-cli": "^9.7.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "opencode-aidlc": "^0.1.0",
    "playwright": "^1.60.0",
    "prisma": "^7.8.0",
    "tailwindcss": "4.3.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.2",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
